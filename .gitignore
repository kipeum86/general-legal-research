# Generated report artifacts
output/reports/
output/*.docx

# Session state & intermediate artifacts
output/checkpoint.json
output/research-plan.json
output/research-result.json
output/analysis-result.json

# Python virtual environment
.venv/

# Python cache
__pycache__/
**/__pycache__/
*.py[cod]

# Environment variables (API keys)
.env

# Local MCP server installs
.mcp/

# User-specific profile (local only — generated by /onboard)
user-config.json

# Agent-generated knowledge base (local only)
knowledge/

# Attorney materials library (confidential, local only)
library/

# Conversation logs (folder tracked, contents ignored)
logs/*
!logs/.gitkeep

# macOS metadata
.DS_Store

# Quarantined ingest artifacts (may contain prompt-injection payloads)
library/inbox/_quarantine/

# Local-only TODO notes (generic pattern; specific filenames live in .git/info/exclude)
/TODO.md
/todo.md
/TODOS.md

# NOTE: Do not list specific confidential filenames here. Public .gitignore
# entries leak the existence and naming of sensitive artifacts.
# Put per-file ignores for confidential matters in .git/info/exclude
# (see docs/security.md — trust boundaries).
.claude/settings.local.json

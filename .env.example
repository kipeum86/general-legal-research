# Korean Open Law API (열린법령 API)
# OC = API 인증 키 (law.go.kr 회원 이메일 ID 앞부분)
# Used by: scripts/open_law_api.py (file-based caching CLI)
OPEN_LAW_OC=your_oc_key
# Note: The korean-law MCP server (.mcp.json) uses LAW_OC instead of OPEN_LAW_OC.
# Both should have the same value. Set LAW_OC in .mcp.json directly.

# EUR-Lex SOAP Webservice (register at eur-lex.europa.eu → Webservice registration)
EURLEX_USERNAME=your_eurlex_username
EURLEX_PASSWORD=your_eurlex_password

# AgentSkills MCP
CASE_API_KEY=your_case_api_key

# Web researcher MCP launch commands
TAVILY_MCP_SERVER_CMD=tavily-mcp
BRAVE_MCP_SERVER_CMD=brave-search-mcp
FETCH_MCP_SERVER_CMD=fetch-mcp

# Optional provider keys (depends on your MCP server setup)
TAVILY_API_KEY=
BRAVE_API_KEY=
